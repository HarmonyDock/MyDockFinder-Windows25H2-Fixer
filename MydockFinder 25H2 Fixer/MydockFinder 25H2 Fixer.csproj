  <ItemGroup>
    <None Remove="Starter.exe" />
  </ItemGroup>


  <ItemGroup>
    <Content Include="ico130.ico" />
  </ItemGroup>


  <ItemGroup>
    <EmbeddedResource Include="Starter.exe" />
  </ItemGroup>

</Project>
