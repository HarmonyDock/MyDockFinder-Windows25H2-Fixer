<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>MydockFinder_25H2_Fixer</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <StartupObject>MydockFinder_25H2_Fixer.App</StartupObject>
    <ApplicationIcon>ico130.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
