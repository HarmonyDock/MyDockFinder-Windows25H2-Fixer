<Window x:Class="LnkToExeConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyDockFinder Windows25H2修复工具" Height="400" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Button x:Name="MydockFolder" Content="选择MyDockFinder根目录" HorizontalAlignment="Center" VerticalAlignment="Center" Click="MydockFolder_Click"/>
        <TextBlock x:Name="foldertext" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top"/>
        <Button x:Name="add" Content="+" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50" FontSize="18" Visibility="Hidden" Click="add_Click"/>
    </Grid>
</Window>